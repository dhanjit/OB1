# Copy to .env and adjust. Compose reads from .env automatically.

OB1_DB_NAME=openbrain
OB1_DB_USER=openbrain
OB1_DB_PASSWORD=openbrain
OB1_DB_PORT=5433
OB1_DB_HOST=127.0.0.1

# Ollama
OB1_EMBED_MODEL=nomic-embed-text
OB1_EMBED_DIM=768
OB1_OLLAMA_URL=http://127.0.0.1:11434

# Optional LLM metadata extractor (off by default). Supported: anthropic, openai, gemini, none
OB1_METADATA_PROVIDER=none
# OB1_METADATA_MODEL=claude-haiku-4-5
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=
